# Database (Supabase PostgreSQL)
# Format: postgresql://user:password@host:5432/database
# Get from: Supabase Dashboard > Project Settings > Database > URI
DATABASE_URL=postgresql://user:password@host:5432/personal_app

# Supabase Storage (for ebooks and covers)
# Get from: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Get from: Supabase Dashboard > Project Settings > API > Service Role Secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Authentication - WebAuthn / Passkey
# The domain name or IP where your app is hosted (used for WebAuthn verification)
NEXT_PUBLIC_WEBAUTHN_RP_ID=localhost
# The friendly name displayed during passkey registration
NEXT_PUBLIC_WEBAUTHN_RP_NAME=Personal App
# The exact origin URL (including protocol and port) for WebAuthn verification
NEXT_PUBLIC_WEBAUTHN_ORIGIN=http://localhost:3000

# Authentication - JWT Sessions
# Generate with: openssl rand -base64 32 (must be at least 32 characters)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long

# Session Configuration
# Set to 'true' in production (requires HTTPS)
SESSION_COOKIE_SECURE=false
# Cookie SameSite attribute: lax, strict, or none
SESSION_COOKIE_SAME_SITE=lax
# Session max age in seconds (604800 = 7 days)
SESSION_MAX_AGE=604800

# AI Providers
# Anthropic Claude API key (used if ANTHROPIC_API_KEY is set)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (fallback if Anthropic key not set)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Application Configuration
NEXT_PUBLIC_APP_NAME=Mi App Personal
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# iCloud Agent Integration
# Token for the local iCloud agent to authenticate uploads
# Generate with: openssl rand -hex 32
AGENT_INGEST_TOKEN=your-agent-token-here
# The user ID (from users table) that the agent uploads on behalf of
AGENT_USER_ID=your-user-uuid-here
