# Required environment variables

# Path to the iCloud Drive folder to watch (e.g., ~/Library/Mobile\ Documents/com~apple~CloudDocs/)
ICLOUD_WATCH_PATH=/path/to/icloud/drive

# Backend API configuration
BACKEND_URL=https://your-app.com
AGENT_TOKEN=your-secret-agent-token

# Optional configuration

# Comma-separated list of allowed file extensions
# Default: .epub,.pdf
ALLOWED_EXTENSIONS=.epub,.pdf

# Maximum file size in MB
# Default: 100
MAX_FILE_SIZE_MB=100

# Minimum file age in seconds (avoid uploading while syncing)
# Default: 5
MIN_FILE_AGE_SECONDS=5

# Retry settings
# Default: 3
MAX_RETRIES=3
# Default: 1000
RETRY_DELAY_MS=1000

# Queue concurrency (number of simultaneous uploads)
# Default: 2
QUEUE_CONCURRENCY=2

# File watcher polling interval in milliseconds
# Default: 2000
POLLING_INTERVAL_MS=2000

# Log level: debug, info, warn, error
# Default: info
LOG_LEVEL=info

# State file path (stores processed files and failed attempts)
# Default: ./agent-state.json
STATE_FILE=./agent-state.json
